{
  "name": "catering-agents-platform",
  "private": true,
  "type": "module",
  "workspaces": [
    "shared-core",
    "intake-service",
    "ingestion-service",
    "offer-service",
    "production-service",
    "print-export",
    "backoffice-ui"
  ],
  "scripts": {
    "build": "tsc --noEmit && npm --workspace @catering/backoffice-ui run build",
    "test": "vitest run",
    "checkpoint": "bash ./scripts/create-checkpoint.sh",
    "import:recipes:caterings": "tsx scripts/import-catering-recipes.ts",
    "local:start": "bash ./scripts/start-local-stack.sh --seed-demo",
    "local:stop": "bash ./scripts/stop-local-stack.sh",
    "local:status": "bash ./scripts/status-local-stack.sh",
    "dev:ui": "npm --workspace @catering/backoffice-ui run dev",
    "dev:intake": "tsx intake-service/src/server.ts",
    "dev:ingestion": "tsx ingestion-service/src/server.ts",
    "dev:offer": "tsx offer-service/src/server.ts",
    "dev:production": "tsx production-service/src/server.ts",
    "dev:exports": "tsx print-export/src/server.ts",
    "deploy:hetzner": "bash ./platform-infra/scripts/deploy-hetzner.sh",
    "smoke:deploy": "bash ./platform-infra/scripts/smoke-check.sh"
  },
  "dependencies": {
    "@fastify/multipart": "^9.0.3",
    "@mozilla/readability": "^0.6.0",
    "@vitejs/plugin-react": "^5.1.4",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "fastify": "^5.6.1",
    "jsdom": "^26.1.0",
    "pdf-parse": "^1.1.1",
    "pg": "^8.20.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "vite": "^7.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@types/jsdom": "^28.0.0",
    "@types/node": "^24.3.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/pg": "^8.18.0",
    "@types/react": "^19.1.11",
    "@types/react-dom": "^19.1.7",
    "pg-mem": "^3.0.14",
    "tsx": "^4.20.4",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
